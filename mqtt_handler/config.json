{
    "MQTT":
    {
        "client_id": "GHC",
        "address": "localhost",
        "port": 1883,
        "subscription_topics": ["ghc/status_update", "ghc/output_update"],
        "publish_topics": ["ghc/response", "ghc/heartbeat", "ghc/online"],
        "QOS": 2,
        "keep_alive": 60,
        "last_will":
        {
            "message_online": "{\"id\": \"ghc\", \"online\": true}",
            "message_offline": "{\"id\": \"ghc\", \"online\": false}",
            "topic": "ghc/online",
            "QOS": 2,
            "retain": true
        },
        "heartbeat_interval": 60
    }
}
